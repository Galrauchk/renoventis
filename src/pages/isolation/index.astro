---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import LeadGenForm from '../../components/LeadGenForm.astro';
import FAQ from '../../components/FAQ.astro';
import AideCard from '../../components/AideCard.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Isolation thermique',
  description: 'Guide complet isolation thermique : combles, murs, sol, fenêtres. Prix et aides 2026.',
  provider: { '@type': 'Organization', name: 'Renoventis' },
  areaServed: { '@type': 'Country', name: 'France' },
};

const faqItems = [
  { question: "Quel est le prix de l'isolation des combles perdus au m² ?", answer: "Le prix de l'isolation des combles perdus varie entre 20€ et 60€/m² selon la technique (soufflage ou déroulage) et l'isolant choisi. Le soufflage de laine de verre ou de roche est la solution la plus économique, autour de 20-35€/m²." },
  { question: "Quelles aides pour isoler sa maison en 2026 ?", answer: "En 2026, vous pouvez bénéficier de MaPrimeRénov' (jusqu'à 25€/m² pour les combles, 75€/m² pour les murs), des CEE (primes énergie), de l'Éco-PTZ (jusqu'à 50 000€) et d'aides locales. Ces aides sont cumulables." },
  { question: "L'isolation par l'extérieur est-elle plus efficace ?", answer: "L'isolation par l'extérieur (ITE) est plus performante car elle supprime les ponts thermiques et ne réduit pas la surface habitable. Elle est cependant plus coûteuse (120-200€/m²) mais bénéficie d'aides plus importantes." },
  { question: "Faut-il un artisan RGE pour l'isolation ?", answer: "Oui, un artisan certifié RGE (Reconnu Garant de l'Environnement) est obligatoire pour bénéficier des aides MaPrimeRénov' et des CEE. Vérifiez la certification sur le site france-renov.gouv.fr." },
  { question: "Quelle est la meilleure isolation pour les murs ?", answer: "L'isolation par l'extérieur (ITE) offre les meilleures performances. En isolation intérieure, la laine de roche ou de verre en panneaux rigides avec une épaisseur de 12-16 cm offre un excellent rapport qualité/prix." },
  { question: "Combien de temps durent les travaux d'isolation ?", answer: "L'isolation des combles par soufflage prend 1 journée. L'isolation des murs par l'intérieur nécessite 3-5 jours. L'ITE peut prendre 2-4 semaines selon la surface et la complexité du chantier." },
  { question: "L'isolation réduit-elle vraiment les factures ?", answer: "Oui, significativement. L'isolation des combles peut réduire vos factures de chauffage de 25-30%. L'isolation complète (combles + murs + sol) peut générer jusqu'à 60% d'économies sur le chauffage." },
  { question: "Peut-on isoler un logement en location ?", answer: "Les travaux d'isolation sont à la charge du propriétaire. Le locataire peut en bénéficier via un meilleur confort et des factures réduites. Le propriétaire bailleur peut obtenir MaPrimeRénov' pour ces travaux." },
];
---

<BaseLayout
  title="Isolation thermique 2026 : aides, prix et artisans RGE | Renoventis"
  description="Guide complet isolation thermique 2026 : combles, murs, sol, fenêtres. Prix au m², aides MaPrimeRénov et CEE, artisans RGE certifiés."
  jsonLd={jsonLd}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Isolation thermique' }]} />

    <div class="grid lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-extrabold text-text">
          Isolation thermique 2026 : aides, prix et artisans RGE
        </h1>
        <p class="mt-4 text-lg text-text-muted">
          L'isolation est le premier geste de rénovation énergétique. Elle permet de réduire jusqu'à 60% de vos déperditions de chaleur et de bénéficier d'aides conséquentes.
        </p>

        <img src="/illustrations/isolation.svg" alt="Isolation thermique d'une maison" class="mt-8 w-full max-w-xl rounded-2xl" loading="lazy" />

        <div class="mt-12 prose prose-lg max-w-none">
          <h2 class="text-2xl font-heading font-bold text-text">Pourquoi isoler son logement ?</h2>
          <p>L'isolation thermique est la première étape incontournable de toute rénovation énergétique. Dans un logement mal isolé, les déperditions de chaleur se répartissent ainsi :</p>
          <ul>
            <li><strong>Toiture et combles :</strong> 25 à 30% des pertes de chaleur</li>
            <li><strong>Murs :</strong> 20 à 25% des pertes</li>
            <li><strong>Fenêtres :</strong> 10 à 15% des pertes</li>
            <li><strong>Plancher bas :</strong> 7 à 10% des pertes</li>
            <li><strong>Ponts thermiques :</strong> 5 à 10% des pertes</li>
          </ul>

          <h2 class="text-2xl font-heading font-bold text-text">Les types d'isolation</h2>

          <h3 class="text-xl font-heading font-bold text-text">Isolation des combles perdus</h3>
          <p>La technique la plus rapide et la plus rentable. Le soufflage de laine minérale permet d'isoler en quelques heures pour un coût modéré de 20 à 35€/m². C'est le meilleur rapport performance/prix.</p>

          <h3 class="text-xl font-heading font-bold text-text">Isolation des murs par l'extérieur (ITE)</h3>
          <p>L'ITE supprime les ponts thermiques et ne réduit pas la surface habitable. Coût : 120 à 200€/m², mais les aides peuvent couvrir jusqu'à 75€/m² via MaPrimeRénov'.</p>

          <h3 class="text-xl font-heading font-bold text-text">Isolation des murs par l'intérieur (ITI)</h3>
          <p>Solution plus économique (40 à 80€/m²) qui réduit légèrement la surface habitable. Idéale quand l'ITE n'est pas possible (façade classée, copropriété).</p>

          <h3 class="text-xl font-heading font-bold text-text">Isolation du plancher bas</h3>
          <p>Souvent négligée, l'isolation du sol permet de gagner en confort et de réduire la sensation de froid. Coût : 30 à 60€/m².</p>

          <h3 class="text-xl font-heading font-bold text-text">Remplacement des fenêtres</h3>
          <p>Le passage en double ou triple vitrage améliore le confort acoustique et thermique. Comptez 500 à 1 200€ par fenêtre, aides déduites.</p>

          <h2 class="text-2xl font-heading font-bold text-text">Prix de l'isolation par type de travaux</h2>
        </div>

        <!-- Tableau prix -->
        <div class="mt-8 overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-primary text-white">
                <th class="px-4 py-3 text-left font-semibold rounded-tl-lg">Type d'isolation</th>
                <th class="px-4 py-3 text-left font-semibold">Prix au m²</th>
                <th class="px-4 py-3 text-left font-semibold">Aide MaPrimeRénov'</th>
                <th class="px-4 py-3 text-left font-semibold rounded-tr-lg">Économies</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-100">
                <td class="px-4 py-3 font-medium">Combles perdus</td>
                <td class="px-4 py-3">20-60€/m²</td>
                <td class="px-4 py-3 text-accent-warm font-semibold">25€/m²</td>
                <td class="px-4 py-3">25-30%</td>
              </tr>
              <tr class="border-b border-gray-100 bg-surface">
                <td class="px-4 py-3 font-medium">Murs extérieur (ITE)</td>
                <td class="px-4 py-3">120-200€/m²</td>
                <td class="px-4 py-3 text-accent-warm font-semibold">75€/m²</td>
                <td class="px-4 py-3">20-25%</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="px-4 py-3 font-medium">Murs intérieur (ITI)</td>
                <td class="px-4 py-3">40-80€/m²</td>
                <td class="px-4 py-3 text-accent-warm font-semibold">25€/m²</td>
                <td class="px-4 py-3">15-20%</td>
              </tr>
              <tr class="border-b border-gray-100 bg-surface">
                <td class="px-4 py-3 font-medium">Plancher bas</td>
                <td class="px-4 py-3">30-60€/m²</td>
                <td class="px-4 py-3 text-accent-warm font-semibold">15€/m²</td>
                <td class="px-4 py-3">7-10%</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium">Fenêtres double vitrage</td>
                <td class="px-4 py-3">500-1200€/unité</td>
                <td class="px-4 py-3 text-accent-warm font-semibold">100€/unité</td>
                <td class="px-4 py-3">10-15%</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Aides -->
        <div class="mt-12">
          <h2 class="text-2xl font-heading font-bold text-text mb-6">Aides disponibles pour l'isolation</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            <AideCard title="MaPrimeRénov'" montant="25 à 75€/m²" description="Selon le type d'isolation et vos revenus." conditions="Logement de plus de 15 ans, artisan RGE" href="/aides-renovation/" />
            <AideCard title="CEE" montant="10 à 20€/m²" description="Prime énergie cumulable avec MaPrimeRénov'." conditions="Aucune condition de revenus" href="/guides/cee-certificats-energie/" />
            <AideCard title="Éco-PTZ" montant="Jusqu'à 50 000€" description="Prêt sans intérêt pour financer le reste à charge." conditions="Sans condition de revenus" href="/guides/eco-ptz-conditions-2026/" />
            <AideCard title="TVA réduite" montant="5,5%" description="TVA à taux réduit sur les travaux d'isolation." conditions="Logement de plus de 2 ans" />
          </div>
        </div>

        <FAQ items={faqItems} />
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">
          <LeadGenForm travaux="Isolation thermique" title="Devis isolation gratuits" />

          <div class="bg-white rounded-2xl border border-gray-100 p-6">
            <h3 class="text-lg font-heading font-bold text-text mb-4">Guides isolation</h3>
            <ul class="space-y-3">
              <li><a href="/guides/isolation-combles-perdus-prix/" class="text-sm text-primary hover:text-accent transition-colors">Isolation combles : prix 2026</a></li>
              <li><a href="/guides/isolation-murs-exterieurs-prix/" class="text-sm text-primary hover:text-accent transition-colors">ITE : prix et aides 2026</a></li>
              <li><a href="/guides/dpe-logement-ameliorer/" class="text-sm text-primary hover:text-accent transition-colors">Améliorer son DPE</a></li>
              <li><a href="/guides/renovation-energetique-ordre-travaux/" class="text-sm text-primary hover:text-accent transition-colors">Ordre des travaux</a></li>
            </ul>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
