---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import LeadGenForm from '../../components/LeadGenForm.astro';
import FAQ from '../../components/FAQ.astro';
import AideCard from '../../components/AideCard.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Isolation thermique',
  description: 'Guide complet isolation thermique : combles, murs, sol, fenêtres. Prix et aides 2026.',
  provider: { '@type': 'Organization', name: 'Renoventis' },
  areaServed: { '@type': 'Country', name: 'France' },
};

const faqItems = [
  { question: "Quel est le prix de l'isolation des combles perdus au m² ?", answer: "Le prix de l'isolation des combles perdus varie entre 20€ et 60€/m² selon la technique (soufflage ou déroulage) et l'isolant choisi. Le soufflage de laine de verre ou de roche est la solution la plus économique, autour de 20-35€/m²." },
  { question: "Quelles aides pour isoler sa maison en 2026 ?", answer: "En 2026, vous pouvez bénéficier de MaPrimeRénov' (jusqu'à 25€/m² pour les combles, 75€/m² pour les murs), des CEE (primes énergie), de l'Éco-PTZ (jusqu'à 50 000€) et d'aides locales. Ces aides sont cumulables." },
  { question: "L'isolation par l'extérieur est-elle plus efficace ?", answer: "L'isolation par l'extérieur (ITE) est plus performante car elle supprime les ponts thermiques et ne réduit pas la surface habitable. Elle est cependant plus coûteuse (120-200€/m²) mais bénéficie d'aides plus importantes." },
  { question: "Faut-il un artisan RGE pour l'isolation ?", answer: "Oui, un artisan certifié RGE (Reconnu Garant de l'Environnement) est obligatoire pour bénéficier des aides MaPrimeRénov' et des CEE. Vérifiez la certification sur le site france-renov.gouv.fr." },
  { question: "Quelle est la meilleure isolation pour les murs ?", answer: "L'isolation par l'extérieur (ITE) offre les meilleures performances. En isolation intérieure, la laine de roche ou de verre en panneaux rigides avec une épaisseur de 12-16 cm offre un excellent rapport qualité/prix." },
  { question: "Combien de temps durent les travaux d'isolation ?", answer: "L'isolation des combles par soufflage prend 1 journée. L'isolation des murs par l'intérieur nécessite 3-5 jours. L'ITE peut prendre 2-4 semaines selon la surface et la complexité du chantier." },
  { question: "L'isolation réduit-elle vraiment les factures ?", answer: "Oui, significativement. L'isolation des combles peut réduire vos factures de chauffage de 25-30%. L'isolation complète (combles + murs + sol) peut générer jusqu'à 60% d'économies sur le chauffage." },
  { question: "Peut-on isoler un logement en location ?", answer: "Les travaux d'isolation sont à la charge du propriétaire. Le locataire peut en bénéficier via un meilleur confort et des factures réduites. Le propriétaire bailleur peut obtenir MaPrimeRénov' pour ces travaux." },
];
---

<BaseLayout
  title="Isolation thermique 2026 : aides, prix et artisans RGE | Renoventis"
  description="Guide complet isolation thermique 2026 : combles, murs, sol, fenêtres. Prix au m², aides MaPrimeRénov et CEE, artisans RGE certifiés."
  jsonLd={jsonLd}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Isolation thermique' }]} />

    <div class="grid lg:grid-cols-3 gap-12 lg:gap-16">
      <div class="lg:col-span-2">
        <div class="fade-up">
          <span class="inline-flex items-center px-3 py-1.5 text-xs font-bold uppercase tracking-widest text-accent bg-accent/10 rounded-lg mb-4">Guide complet</span>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-extrabold text-text leading-tight">
            Isolation thermique 2026 : aides, prix et artisans RGE
          </h1>
          <p class="mt-5 text-lg text-text-muted leading-relaxed">
            L'isolation est le premier geste de rénovation énergétique. Elle permet de réduire jusqu'à 60% de vos déperditions de chaleur et de bénéficier d'aides conséquentes.
          </p>
        </div>

        <div class="mt-10 fade-up" style="transition-delay: 0.1s;">
          <img src="/illustrations/isolation.svg" alt="Isolation thermique d'une maison" class="w-full max-w-xl rounded-2xl" loading="lazy" />
        </div>

        <div class="mt-14 prose-premium">
          <h2 class="text-2xl font-heading font-bold text-text">Pourquoi isoler son logement ?</h2>
          <p>L'isolation thermique est la première étape incontournable de toute rénovation énergétique. Dans un logement mal isolé, les déperditions de chaleur se répartissent ainsi :</p>
          <ul class="mt-4 space-y-3">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-accent flex-shrink-0"></span><span class="text-text-muted"><strong class="text-text">Toiture et combles :</strong> 25 à 30% des pertes de chaleur</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-accent flex-shrink-0"></span><span class="text-text-muted"><strong class="text-text">Murs :</strong> 20 à 25% des pertes</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-accent flex-shrink-0"></span><span class="text-text-muted"><strong class="text-text">Fenêtres :</strong> 10 à 15% des pertes</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-accent flex-shrink-0"></span><span class="text-text-muted"><strong class="text-text">Plancher bas :</strong> 7 à 10% des pertes</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-accent flex-shrink-0"></span><span class="text-text-muted"><strong class="text-text">Ponts thermiques :</strong> 5 à 10% des pertes</span></li>
          </ul>

          <h2 class="text-2xl font-heading font-bold text-text mt-12">Les types d'isolation</h2>

          <h3 class="text-xl font-heading font-bold text-text mt-8">Isolation des combles perdus</h3>
          <p class="text-text-muted leading-relaxed">La technique la plus rapide et la plus rentable. Le soufflage de laine minérale permet d'isoler en quelques heures pour un coût modéré de 20 à 35€/m². C'est le meilleur rapport performance/prix.</p>

          <h3 class="text-xl font-heading font-bold text-text mt-8">Isolation des murs par l'extérieur (ITE)</h3>
          <p class="text-text-muted leading-relaxed">L'ITE supprime les ponts thermiques et ne réduit pas la surface habitable. Coût : 120 à 200€/m², mais les aides peuvent couvrir jusqu'à 75€/m² via MaPrimeRénov'.</p>

          <h3 class="text-xl font-heading font-bold text-text mt-8">Isolation des murs par l'intérieur (ITI)</h3>
          <p class="text-text-muted leading-relaxed">Solution plus économique (40 à 80€/m²) qui réduit légèrement la surface habitable. Idéale quand l'ITE n'est pas possible (façade classée, copropriété).</p>

          <h3 class="text-xl font-heading font-bold text-text mt-8">Isolation du plancher bas</h3>
          <p class="text-text-muted leading-relaxed">Souvent négligée, l'isolation du sol permet de gagner en confort et de réduire la sensation de froid. Coût : 30 à 60€/m².</p>

          <h3 class="text-xl font-heading font-bold text-text mt-8">Remplacement des fenêtres</h3>
          <p class="text-text-muted leading-relaxed">Le passage en double ou triple vitrage améliore le confort acoustique et thermique. Comptez 500 à 1 200€ par fenêtre, aides déduites.</p>

          <h2 class="text-2xl font-heading font-bold text-text mt-12">Prix de l'isolation par type de travaux</h2>
        </div>

        <!-- Tableau prix -->
        <div class="mt-8 overflow-x-auto fade-up">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gradient-to-r from-primary to-dark text-white">
                <th class="px-5 py-4 text-left font-semibold rounded-tl-xl">Type d'isolation</th>
                <th class="px-5 py-4 text-left font-semibold">Prix au m²</th>
                <th class="px-5 py-4 text-left font-semibold">Aide MaPrimeRénov'</th>
                <th class="px-5 py-4 text-left font-semibold rounded-tr-xl">Économies</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr class="hover:bg-surface/50 transition-colors">
                <td class="px-5 py-4 font-medium text-text">Combles perdus</td>
                <td class="px-5 py-4 text-text-muted">20-60€/m²</td>
                <td class="px-5 py-4 font-bold text-accent-warm">25€/m²</td>
                <td class="px-5 py-4 text-text-muted">25-30%</td>
              </tr>
              <tr class="hover:bg-surface/50 transition-colors">
                <td class="px-5 py-4 font-medium text-text">Murs extérieur (ITE)</td>
                <td class="px-5 py-4 text-text-muted">120-200€/m²</td>
                <td class="px-5 py-4 font-bold text-accent-warm">75€/m²</td>
                <td class="px-5 py-4 text-text-muted">20-25%</td>
              </tr>
              <tr class="hover:bg-surface/50 transition-colors">
                <td class="px-5 py-4 font-medium text-text">Murs intérieur (ITI)</td>
                <td class="px-5 py-4 text-text-muted">40-80€/m²</td>
                <td class="px-5 py-4 font-bold text-accent-warm">25€/m²</td>
                <td class="px-5 py-4 text-text-muted">15-20%</td>
              </tr>
              <tr class="hover:bg-surface/50 transition-colors">
                <td class="px-5 py-4 font-medium text-text">Plancher bas</td>
                <td class="px-5 py-4 text-text-muted">30-60€/m²</td>
                <td class="px-5 py-4 font-bold text-accent-warm">15€/m²</td>
                <td class="px-5 py-4 text-text-muted">7-10%</td>
              </tr>
              <tr class="hover:bg-surface/50 transition-colors">
                <td class="px-5 py-4 font-medium text-text">Fenêtres double vitrage</td>
                <td class="px-5 py-4 text-text-muted">500-1200€/unité</td>
                <td class="px-5 py-4 font-bold text-accent-warm">100€/unité</td>
                <td class="px-5 py-4 text-text-muted">10-15%</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Aides -->
        <div class="mt-14 fade-up">
          <h2 class="text-2xl font-heading font-bold text-text mb-6">Aides disponibles pour l'isolation</h2>
          <div class="grid sm:grid-cols-2 gap-5">
            <AideCard title="MaPrimeRénov'" montant="25 à 75€/m²" description="Selon le type d'isolation et vos revenus." conditions="Logement de plus de 15 ans, artisan RGE" href="/aides-renovation/" />
            <AideCard title="CEE" montant="10 à 20€/m²" description="Prime énergie cumulable avec MaPrimeRénov'." conditions="Aucune condition de revenus" href="/guides/cee-certificats-energie/" />
            <AideCard title="Éco-PTZ" montant="Jusqu'à 50 000€" description="Prêt sans intérêt pour financer le reste à charge." conditions="Sans condition de revenus" href="/guides/eco-ptz-conditions-2026/" />
            <AideCard title="TVA réduite" montant="5,5%" description="TVA à taux réduit sur les travaux d'isolation." conditions="Logement de plus de 2 ans" />
          </div>
        </div>

        <FAQ items={faqItems} />
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">
          <LeadGenForm travaux="Isolation thermique" title="Devis isolation gratuits" />

          <div class="card-premium p-6">
            <h3 class="text-lg font-heading font-bold text-text mb-4">Guides isolation</h3>
            <ul class="space-y-3">
              <li><a href="/guides/isolation-combles-perdus-prix/" class="text-sm text-primary hover:text-accent transition-colors flex items-center gap-2"><svg class="w-3.5 h-3.5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>Isolation combles : prix 2026</a></li>
              <li><a href="/guides/isolation-murs-exterieurs-prix/" class="text-sm text-primary hover:text-accent transition-colors flex items-center gap-2"><svg class="w-3.5 h-3.5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>ITE : prix et aides 2026</a></li>
              <li><a href="/guides/dpe-logement-ameliorer/" class="text-sm text-primary hover:text-accent transition-colors flex items-center gap-2"><svg class="w-3.5 h-3.5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>Améliorer son DPE</a></li>
              <li><a href="/guides/renovation-energetique-ordre-travaux/" class="text-sm text-primary hover:text-accent transition-colors flex items-center gap-2"><svg class="w-3.5 h-3.5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>Ordre des travaux</a></li>
            </ul>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
