---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import LeadGenForm from '../../components/LeadGenForm.astro';
import FAQ from '../../components/FAQ.astro';
import AideCard from '../../components/AideCard.astro';

const faqItems = [
  { question: "Combien coûte une installation de panneaux solaires ?", answer: "Pour une installation de 3 kWc (8-10 panneaux), comptez entre 7 000€ et 12 000€ pose comprise. Après déduction de la prime à l'autoconsommation, le coût net est de 5 000 à 10 000€." },
  { question: "Les panneaux solaires sont-ils rentables en France ?", answer: "Oui, avec un retour sur investissement en 8 à 12 ans selon votre région et votre consommation. Les panneaux produisent pendant 25-30 ans, générant des économies substantielles." },
  { question: "Quelle prime pour les panneaux solaires en 2026 ?", answer: "La prime à l'autoconsommation est de 260-390€/kWc en 2026 (soit environ 780 à 2 340€ pour 3 à 6 kWc). Cette prime est versée en une fois à la mise en service." },
  { question: "Combien de panneaux solaires pour une maison ?", answer: "Pour une maison de 100m², 8-12 panneaux (3-4 kWc) couvrent environ 30-50% des besoins. Pour l'autoconsommation totale, 15-20 panneaux (6 kWc) avec batterie sont nécessaires." },
  { question: "Faut-il un artisan RGE pour les panneaux solaires ?", answer: "Oui, un artisan certifié RGE QualiPV est obligatoire pour bénéficier de la prime à l'autoconsommation et de l'obligation d'achat EDF." },
  { question: "Panneaux solaires : autoconsommation ou revente totale ?", answer: "L'autoconsommation avec vente du surplus est le plus rentable en 2026. Vous consommez votre production et revendez l'excédent à EDF OA à un tarif garanti pendant 20 ans." },
  { question: "Les panneaux solaires fonctionnent-ils par temps couvert ?", answer: "Oui, les panneaux photovoltaïques produisent même par temps nuageux, avec un rendement réduit d'environ 30-50%. La production annuelle dépend de l'ensoleillement de votre région." },
  { question: "Quelle est la durée de vie des panneaux solaires ?", answer: "Les panneaux solaires ont une durée de vie de 25 à 30 ans avec une garantie de performance de 80% à 25 ans. L'onduleur doit être remplacé tous les 10-12 ans." },
];
---

<BaseLayout
  title="Panneaux solaires 2026 : installation, prix et rentabilité | Renoventis"
  description="Guide panneaux solaires 2026 : prix installation, rentabilité, prime autoconsommation, production kWh. Devis gratuits d'installateurs RGE."
  jsonLd={{ '@context': 'https://schema.org', '@type': 'Service', name: 'Installation panneaux solaires', provider: { '@type': 'Organization', name: 'Renoventis' }, areaServed: { '@type': 'Country', name: 'France' } }}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Panneaux solaires' }]} />

    <div class="grid lg:grid-cols-3 gap-12 lg:gap-16">
      <div class="lg:col-span-2">
        <div class="fade-up">
          <span class="inline-flex items-center px-3 py-1.5 text-xs font-bold uppercase tracking-widest text-accent bg-accent/10 rounded-lg mb-4">Guide complet</span>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-extrabold text-text">
            Panneaux solaires 2026 : installation, prix et rentabilité
          </h1>
        </div>
        <p class="mt-4 text-lg text-text-muted leading-relaxed">
          Les panneaux solaires photovoltaïques permettent de produire votre propre électricité et de réduire vos factures. En 2026, la prime à l'autoconsommation rend l'investissement encore plus attractif.
        </p>


        <div class="mt-12 prose prose-lg max-w-none fade-up">
          <h2 class="text-2xl font-heading font-bold text-text">Pourquoi installer des panneaux solaires ?</h2>
          <p>L'installation de panneaux solaires photovoltaïques est un investissement rentable qui vous permet de :</p>
          <ul>
            <li>Produire votre propre électricité verte</li>
            <li>Réduire vos factures de 30 à 70%</li>
            <li>Revendre le surplus à EDF OA</li>
            <li>Valoriser votre bien immobilier</li>
            <li>Contribuer à la transition énergétique</li>
          </ul>

          <h2 class="text-2xl font-heading font-bold text-text">Prix d'une installation solaire en 2026</h2>
          <p>Le prix dépend de la puissance installée, du type de pose (surimposition ou intégré au bâti) et de la complexité du chantier.</p>
        </div>

        <div class="mt-8 overflow-x-auto fade-up">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-gradient-to-r from-primary to-dark text-white">
                <th class="px-4 py-3 text-left font-semibold rounded-tl-xl">Puissance</th>
                <th class="px-4 py-3 text-left font-semibold">Nb panneaux</th>
                <th class="px-4 py-3 text-left font-semibold">Prix posé</th>
                <th class="px-4 py-3 text-left font-semibold">Prime autoconso</th>
                <th class="px-4 py-3 text-left font-semibold rounded-tr-xl">Production/an</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-100 hover:bg-surface/50 transition-colors">
                <td class="px-4 py-3 font-medium">3 kWc</td>
                <td class="px-4 py-3">8-10</td>
                <td class="px-4 py-3">7 000-10 000€</td>
                <td class="px-4 py-3 text-accent-warm font-semibold">1 170€</td>
                <td class="px-4 py-3">3 000-3 800 kWh</td>
              </tr>
              <tr class="border-b border-gray-100 hover:bg-surface/50 transition-colors">
                <td class="px-4 py-3 font-medium">6 kWc</td>
                <td class="px-4 py-3">15-18</td>
                <td class="px-4 py-3">11 000-16 000€</td>
                <td class="px-4 py-3 text-accent-warm font-semibold">1 560€</td>
                <td class="px-4 py-3">6 000-7 600 kWh</td>
              </tr>
              <tr class="hover:bg-surface/50 transition-colors">
                <td class="px-4 py-3 font-medium">9 kWc</td>
                <td class="px-4 py-3">22-26</td>
                <td class="px-4 py-3">15 000-22 000€</td>
                <td class="px-4 py-3 text-accent-warm font-semibold">2 340€</td>
                <td class="px-4 py-3">9 000-11 400 kWh</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="mt-12 fade-up">
          <h2 class="text-2xl font-heading font-bold text-text mb-6">Aides pour les panneaux solaires</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            <AideCard title="Prime autoconsommation" montant="260 à 390€/kWc" description="Prime versée à la mise en service." conditions="Autoconsommation avec vente surplus, installateur RGE" />
            <AideCard title="Obligation d'achat" montant="0,13€/kWh" description="Tarif garanti 20 ans pour le surplus." conditions="Contrat EDF OA, installation ≤ 100 kWc" />
          </div>
        </div>

        <FAQ items={faqItems} />
      </div>

      <aside class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">
          <LeadGenForm travaux="Panneaux solaires" title="Devis solaire gratuits" />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
