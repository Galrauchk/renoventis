---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import LeadGenForm from '../../components/LeadGenForm.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.data.title,
  description: guide.data.description,
  datePublished: guide.data.publishDate,
  dateModified: guide.data.updatedDate || guide.data.publishDate,
  author: { '@type': 'Organization', name: 'Renoventis', url: 'https://renoventis.fr' },
  publisher: { '@type': 'Organization', name: 'Renoventis', logo: { '@type': 'ImageObject', url: 'https://renoventis.fr/logo-renoventis.svg' } },
};
---

<BaseLayout
  title={`${guide.data.title} | Renoventis`}
  description={guide.data.description}
  type="article"
  publishDate={guide.data.publishDate}
  jsonLd={jsonLd}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Guides', href: '/guides/' }, { label: guide.data.title }]} />

    <div class="grid lg:grid-cols-3 gap-12">
      <article class="lg:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <span class="inline-block px-2.5 py-1 text-xs font-medium text-primary bg-surface rounded-full">{guide.data.category}</span>
          {guide.data.aideMontant && (
            <span class="inline-block px-2.5 py-1 text-xs font-semibold text-white bg-accent-warm rounded-full">
              Aide jusqu'à {guide.data.aideMontant}
            </span>
          )}
        </div>

        <h1 class="text-3xl md:text-4xl font-heading font-extrabold text-text">{guide.data.title}</h1>
        <p class="mt-4 text-lg text-text-muted">{guide.data.description}</p>

        <div class="mt-3 text-sm text-text-muted">
          Mis à jour le {new Date(guide.data.publishDate).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </div>

        <div class="mt-4 p-4 bg-surface rounded-xl border border-accent/20 text-sm">
          <p class="font-medium text-text">Sources officielles :</p>
          <p class="text-text-muted mt-1">ANAH (Agence Nationale de l'Habitat) · ADEME · france-renov.gouv.fr</p>
        </div>

        <div class="mt-8 prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-text prose-a:text-primary hover:prose-a:text-accent">
          <Content />
        </div>

        <!-- CTA bottom -->
        <div class="mt-12 bg-gradient-to-br from-primary to-dark rounded-2xl p-8 text-center">
          <h3 class="text-xl font-heading font-bold text-white">Prêt à lancer vos travaux ?</h3>
          <p class="mt-2 text-sm text-white/70">Obtenez 3 devis gratuits d'artisans RGE certifiés.</p>
          <a href="/devis/" class="mt-4 inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-accent-warm hover:bg-amber-500 rounded-lg transition-colors">
            Demander mes devis gratuits
          </a>
        </div>
      </article>

      <aside class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">
          <LeadGenForm title="Obtenez des devis gratuits" />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
