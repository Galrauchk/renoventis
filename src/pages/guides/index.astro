---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');
const sortedGuides = guides.sort((a, b) => b.data.publishDate.localeCompare(a.data.publishDate));

const categories = [...new Set(guides.map(g => g.data.category))];
---

<BaseLayout
  title="Guides rénovation énergétique 2026 | Renoventis"
  description="Guides experts rénovation énergétique : MaPrimeRénov, isolation, pompe à chaleur, panneaux solaires, DPE. Conseils pratiques et aides 2026."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Guides' }]} />

    <div class="max-w-3xl mb-12">
      <h1 class="text-3xl md:text-4xl font-heading font-extrabold text-text">Guides rénovation énergétique</h1>
      <p class="mt-4 text-lg text-text-muted">Retrouvez nos guides experts pour comprendre les aides, comparer les travaux et réussir votre projet de rénovation.</p>
    </div>

    <!-- Categories filter -->
    <div class="flex flex-wrap gap-2 mb-8">
      <span class="px-3 py-1.5 text-sm font-medium text-white bg-primary rounded-full">Tous</span>
      {categories.map(cat => (
        <span class="px-3 py-1.5 text-sm font-medium text-text-muted bg-surface rounded-full hover:bg-gray-200 transition-colors cursor-pointer">{cat}</span>
      ))}
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {sortedGuides.map(guide => (
        <ArticleCard
          title={guide.data.title}
          description={guide.data.description}
          href={`/guides/${guide.id}/`}
          category={guide.data.category}
          aideMontant={guide.data.aideMontant}
        />
      ))}
    </div>
  </div>
</BaseLayout>
