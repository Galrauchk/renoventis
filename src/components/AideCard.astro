---
interface Props {
  title: string;
  montant: string;
  description: string;
  conditions: string;
  href?: string;
}

const { title, montant, description, conditions, href } = Astro.props;
---

<div class="group card-premium p-6 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-accent/5 to-transparent rounded-bl-full"></div>
  <h3 class="text-lg font-heading font-bold text-text">{title}</h3>
  <p class="mt-3 text-2xl font-heading font-extrabold text-gradient-warm">{montant}</p>
  <p class="mt-3 text-sm text-text-muted leading-relaxed">{description}</p>
  <p class="mt-4 text-xs text-text-muted/80 border-t border-gray-100 pt-4 leading-relaxed">{conditions}</p>
  {href && (
    <a href={href} class="mt-4 inline-flex items-center text-sm font-semibold text-primary hover:text-accent transition-colors group/link">
      En savoir plus
      <svg class="w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
    </a>
  )}
</div>
