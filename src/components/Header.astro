---
const currentPath = Astro.url.pathname;

const travauxLinks = [
  { href: '/isolation/', label: 'Isolation thermique', icon: '🏠' },
  { href: '/pompe-a-chaleur/', label: 'Pompe à chaleur', icon: '♨️' },
  { href: '/panneaux-solaires/', label: 'Panneaux solaires', icon: '☀️' },
  { href: '/chaudiere-biomasse/', label: 'Chaudière biomasse', icon: '🪵' },
  { href: '/ventilation-vmc/', label: 'VMC double flux', icon: '💨' },
];

const navLinks = [
  { href: '/aides-renovation/', label: 'Aides' },
  { href: '/simulateurs/', label: 'Simulateur' },
  { href: '/guides/', label: 'Guides' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 lg:h-22">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0 relative z-10">
        <img src="/logo-renoventis-light.svg" alt="Renoventis" class="h-8 lg:h-9 w-auto" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        <!-- Travaux dropdown -->
        <div class="relative group">
          <button aria-expanded="false" aria-haspopup="true" class="flex items-center gap-1.5 px-4 py-2.5 text-sm font-medium text-white/90 hover:text-white rounded-xl hover:bg-white/10 transition-all duration-200">
            Travaux
            <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0">
            <div class="glass-light rounded-2xl shadow-2xl shadow-primary/10 py-3 min-w-[260px] overflow-hidden">
              {travauxLinks.map(link => (
                <a href={link.href} class:list={["flex items-center gap-3 px-5 py-3 text-sm hover:bg-accent/5 transition-all duration-200", currentPath.startsWith(link.href) ? 'text-primary font-semibold bg-accent/10' : 'text-text hover:text-primary']}>
                  <span class="text-base">{link.icon}</span>
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        {navLinks.map(link => (
          <a href={link.href} class:list={["px-4 py-2.5 text-sm font-medium rounded-xl transition-all duration-200", currentPath.startsWith(link.href) ? 'text-white bg-white/20 shadow-inner' : 'text-white/90 hover:text-white hover:bg-white/10']}>
            {link.label}
          </a>
        ))}

        <a href="/devis/" class="ml-4 inline-flex items-center px-6 py-2.5 text-sm font-semibold text-white bg-accent-warm hover:bg-amber-500 rounded-xl transition-all duration-300 shadow-lg shadow-amber-500/20 hover:shadow-xl hover:shadow-amber-500/30 hover:-translate-y-0.5">
          Devis gratuit
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button id="mobile-menu-btn" class="lg:hidden p-2.5 text-white rounded-xl hover:bg-white/10 transition-colors" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg id="menu-open-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="menu-close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden">
    <div class="mx-4 mt-2 glass rounded-2xl p-5 space-y-1">
      <p class="px-3 py-2 text-xs font-semibold text-white/50 uppercase tracking-wider">Travaux</p>
      {travauxLinks.map(link => (
        <a href={link.href} class="flex items-center gap-3 px-3 py-3 text-sm text-white/80 hover:text-white hover:bg-white/10 rounded-xl transition-colors">
          <span>{link.icon}</span>
          {link.label}
        </a>
      ))}
      <div class="border-t border-white/10 my-3"></div>
      {navLinks.map(link => (
        <a href={link.href} class="block px-3 py-3 text-sm text-white/80 hover:text-white hover:bg-white/10 rounded-xl transition-colors">
          {link.label}
        </a>
      ))}
      <div class="pt-3">
        <a href="/devis/" class="block text-center px-5 py-3.5 text-sm font-semibold text-white bg-accent-warm hover:bg-amber-500 rounded-xl shadow-lg shadow-amber-500/20 transition-all">
          Devis gratuit
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const menuBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const openIcon = document.getElementById('menu-open-icon')!;
  const closeIcon = document.getElementById('menu-close-icon')!;

  let isOpen = false;
  menuBtn.addEventListener('click', () => {
    isOpen = !isOpen;
    mobileMenu.classList.toggle('hidden', !isOpen);
    openIcon.classList.toggle('hidden', isOpen);
    closeIcon.classList.toggle('hidden', !isOpen);
    menuBtn.setAttribute('aria-expanded', String(isOpen));
  });

  // Header scroll behavior
  let lastScroll = 0;
  const updateHeader = () => {
    const scrollY = window.scrollY;
    if (scrollY > 40) {
      header.classList.add('header-scrolled');
    } else {
      header.classList.remove('header-scrolled');
    }
    lastScroll = scrollY;
  };

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();
</script>

<style>
  #site-header {
    background: linear-gradient(180deg, rgba(8, 28, 21, 0.8) 0%, rgba(8, 28, 21, 0) 100%);
  }
  #site-header.header-scrolled {
    background: rgba(8, 28, 21, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(82, 183, 136, 0.1);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  }
</style>
