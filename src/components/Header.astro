---
const currentPath = Astro.url.pathname;

const travauxLinks = [
  { href: '/isolation/', label: 'Isolation thermique' },
  { href: '/pompe-a-chaleur/', label: 'Pompe à chaleur' },
  { href: '/panneaux-solaires/', label: 'Panneaux solaires' },
  { href: '/chaudiere-biomasse/', label: 'Chaudière biomasse' },
  { href: '/ventilation-vmc/', label: 'VMC double flux' },
];

const navLinks = [
  { href: '/aides-renovation/', label: 'Aides' },
  { href: '/simulateurs/', label: 'Simulateur' },
  { href: '/guides/', label: 'Guides' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-primary transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img src="/logo-renoventis.svg" alt="Renoventis" class="h-8 lg:h-10 w-auto" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        <!-- Travaux dropdown -->
        <div class="relative group">
          <button aria-expanded="false" aria-haspopup="true" class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-white/90 hover:text-white rounded-lg hover:bg-white/10 transition-colors">
            Travaux
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-xl shadow-xl border border-gray-100 py-2 min-w-[220px]">
              {travauxLinks.map(link => (
                <a href={link.href} class:list={["block px-4 py-2.5 text-sm hover:bg-surface transition-colors", currentPath.startsWith(link.href) ? 'text-primary font-semibold bg-surface' : 'text-text']}>
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        {navLinks.map(link => (
          <a href={link.href} class:list={["px-3 py-2 text-sm font-medium rounded-lg transition-colors", currentPath.startsWith(link.href) ? 'text-white bg-white/20' : 'text-white/90 hover:text-white hover:bg-white/10']}>
            {link.label}
          </a>
        ))}

        <a href="/devis/" class="ml-3 inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-accent-warm hover:bg-amber-500 rounded-lg transition-colors shadow-lg shadow-amber-500/25">
          Devis gratuit
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-white rounded-lg hover:bg-white/10" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg id="menu-open-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="menu-close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-dark/95 backdrop-blur-xl border-t border-white/10">
    <div class="px-4 py-4 space-y-1">
      <p class="px-3 py-2 text-xs font-semibold text-white/50 uppercase tracking-wider">Travaux</p>
      {travauxLinks.map(link => (
        <a href={link.href} class="block px-3 py-2.5 text-sm text-white/80 hover:text-white hover:bg-white/10 rounded-lg">
          {link.label}
        </a>
      ))}
      <div class="border-t border-white/10 my-2"></div>
      {navLinks.map(link => (
        <a href={link.href} class="block px-3 py-2.5 text-sm text-white/80 hover:text-white hover:bg-white/10 rounded-lg">
          {link.label}
        </a>
      ))}
      <div class="pt-2">
        <a href="/devis/" class="block text-center px-5 py-3 text-sm font-semibold text-white bg-accent-warm hover:bg-amber-500 rounded-lg">
          Devis gratuit
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const menuBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const openIcon = document.getElementById('menu-open-icon')!;
  const closeIcon = document.getElementById('menu-close-icon')!;

  let isOpen = false;
  menuBtn.addEventListener('click', () => {
    isOpen = !isOpen;
    mobileMenu.classList.toggle('hidden', !isOpen);
    openIcon.classList.toggle('hidden', isOpen);
    closeIcon.classList.toggle('hidden', !isOpen);
    menuBtn.setAttribute('aria-expanded', String(isOpen));
  });

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header.classList.add('bg-dark/95', 'backdrop-blur-xl', 'shadow-lg');
    } else {
      header.classList.remove('bg-dark/95', 'backdrop-blur-xl', 'shadow-lg');
    }
  });
</script>
