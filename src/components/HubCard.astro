---
interface Props {
  title: string;
  description: string;
  href: string;
  illustration: string;
  aideMontant?: string;
}

const { title, description, href, illustration, aideMontant } = Astro.props;
---

<a href={href} class="group relative bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 hover:-translate-y-1">
  <div class="aspect-[4/3] bg-surface overflow-hidden">
    <img src={illustration} alt={title} class="w-full h-full object-contain p-6 group-hover:scale-105 transition-transform duration-500" loading="lazy" />
  </div>
  <div class="p-5">
    {aideMontant && (
      <span class="inline-block px-2.5 py-1 text-xs font-semibold text-white bg-accent-warm rounded-full mb-3">
        Aide jusqu'à {aideMontant}
      </span>
    )}
    <h3 class="text-lg font-heading font-bold text-text group-hover:text-primary transition-colors">{title}</h3>
    <p class="mt-1.5 text-sm text-text-muted line-clamp-2">{description}</p>
    <span class="mt-3 inline-flex items-center text-sm font-semibold text-primary group-hover:gap-2 transition-all">
      En savoir plus
      <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </span>
  </div>
</a>
