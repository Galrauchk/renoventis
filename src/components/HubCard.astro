---
interface Props {
  title: string;
  description: string;
  href: string;
  illustration: string;
  aideMontant?: string;
}

const { title, description, href, illustration, aideMontant } = Astro.props;
---

<a href={href} class="group card-premium relative overflow-hidden">
  <div class="aspect-[4/3] bg-gradient-to-br from-surface to-white overflow-hidden relative">
    <div class="absolute inset-0 dot-pattern opacity-50"></div>
    <img src={illustration} alt={title} class="relative w-full h-full object-contain p-8 group-hover:scale-110 transition-transform duration-700 ease-out" loading="lazy" />
    {aideMontant && (
      <span class="absolute top-4 right-4 inline-flex items-center px-3 py-1.5 text-xs font-bold text-white bg-gradient-to-r from-amber-500 to-orange-500 rounded-full shadow-lg shadow-amber-500/25">
        Aide {aideMontant}
      </span>
    )}
  </div>
  <div class="p-6">
    <h3 class="text-lg font-heading font-bold text-text group-hover:text-gradient transition-colors duration-300">{title}</h3>
    <p class="mt-2 text-sm text-text-muted leading-relaxed line-clamp-2">{description}</p>
    <div class="mt-4 flex items-center text-sm font-semibold text-accent group-hover:text-primary transition-colors">
      <span>Découvrir</span>
      <svg class="w-4 h-4 ml-1.5 transform group-hover:translate-x-1.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
    </div>
  </div>
</a>
