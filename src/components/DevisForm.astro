---
---

<div class="max-w-2xl mx-auto">
  <div id="devis-form-container">
    <!-- Progress bar -->
    <div class="mb-8">
      <div class="flex items-center justify-between mb-2">
        <span id="step-label" class="text-sm font-medium text-text">Étape 1 sur 4</span>
        <span id="step-percent" class="text-sm font-medium text-accent">25%</span>
      </div>
      <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
        <div id="progress-bar" class="h-full bg-accent rounded-full transition-all duration-500" style="width: 25%"></div>
      </div>
    </div>

    <form id="devis-form" class="space-y-6">
      <!-- Step 1: Type de travaux -->
      <div id="step-1" class="step-panel">
        <h3 class="text-xl font-heading font-bold text-text mb-4">Quels travaux souhaitez-vous réaliser ?</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {[
            'Isolation combles', 'Isolation murs', 'Isolation sol',
            'Pompe à chaleur', 'Panneaux solaires', 'Chaudière biomasse',
            'Fenêtres double vitrage', 'VMC double flux'
          ].map(t => (
            <label class="flex items-center gap-3 p-4 bg-white border border-gray-200 rounded-xl cursor-pointer hover:border-accent transition-colors has-[:checked]:border-accent has-[:checked]:bg-surface">
              <input type="checkbox" name="travaux" value={t} class="w-4 h-4 text-accent border-gray-300 rounded focus:ring-accent" />
              <span class="text-sm font-medium text-text">{t}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- Step 2: Logement -->
      <div id="step-2" class="step-panel hidden">
        <h3 class="text-xl font-heading font-bold text-text mb-4">Votre logement</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Type de logement</label>
            <select name="type_logement" class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none">
              <option value="">Sélectionner</option>
              <option value="maison">Maison individuelle</option>
              <option value="appartement">Appartement</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Surface habitable (m²)</label>
            <input type="number" name="surface" class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none" placeholder="100" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Année de construction</label>
            <select name="annee_construction" class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none">
              <option value="">Sélectionner</option>
              <option value="avant-1975">Avant 1975</option>
              <option value="1975-1990">1975-1990</option>
              <option value="1990-2005">1990-2005</option>
              <option value="2005-2012">2005-2012</option>
              <option value="apres-2012">Après 2012</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">DPE actuel (si connu)</label>
            <select name="dpe_actuel" class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none">
              <option value="">Je ne sais pas</option>
              <option value="A">A</option><option value="B">B</option><option value="C">C</option>
              <option value="D">D</option><option value="E">E</option><option value="F">F</option><option value="G">G</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Step 3: Revenus -->
      <div id="step-3" class="step-panel hidden">
        <h3 class="text-xl font-heading font-bold text-text mb-4">Vos revenus fiscaux de référence</h3>
        <p class="text-sm text-text-muted mb-4">Cette information permet d'estimer vos aides MaPrimeRénov'.</p>
        <div class="space-y-3">
          {[
            { value: 'tres-modestes', label: 'Revenus très modestes', detail: '< 16 229€ (1 pers. Île-de-France)' },
            { value: 'modestes', label: 'Revenus modestes', detail: '< 19 805€ (1 pers. Île-de-France)' },
            { value: 'intermediaires', label: 'Revenus intermédiaires', detail: '< 29 148€ (1 pers. Île-de-France)' },
            { value: 'superieurs', label: 'Revenus supérieurs', detail: '> 29 148€ (1 pers. Île-de-France)' },
          ].map(r => (
            <label class="flex items-start gap-3 p-4 bg-white border border-gray-200 rounded-xl cursor-pointer hover:border-accent transition-colors has-[:checked]:border-accent has-[:checked]:bg-surface">
              <input type="radio" name="revenus" value={r.value} class="mt-0.5 w-4 h-4 text-accent border-gray-300 focus:ring-accent" />
              <div>
                <span class="text-sm font-medium text-text">{r.label}</span>
                <span class="block text-xs text-text-muted mt-0.5">{r.detail}</span>
              </div>
            </label>
          ))}
        </div>
      </div>

      <!-- Step 4: Coordonnées -->
      <div id="step-4" class="step-panel hidden">
        <h3 class="text-xl font-heading font-bold text-text mb-4">Vos coordonnées</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Nom complet</label>
            <input type="text" name="nom" required class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none" placeholder="Jean Dupont" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Email</label>
            <input type="email" name="email" required class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none" placeholder="jean@email.fr" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Téléphone</label>
            <input type="tel" name="telephone" required class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none" placeholder="06 XX XX XX XX" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Code postal</label>
            <input type="text" name="code_postal" required pattern="[0-9]{5}" class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-accent focus:border-transparent outline-none" placeholder="75001" />
          </div>
        </div>
      </div>

      <!-- Navigation buttons -->
      <div class="flex items-center justify-between pt-4">
        <button type="button" id="prev-btn" class="hidden px-5 py-2.5 text-sm font-medium text-text-muted hover:text-text border border-gray-200 rounded-lg transition-colors">
          Précédent
        </button>
        <div></div>
        <button type="button" id="next-btn" class="px-8 py-2.5 text-sm font-semibold text-white bg-primary hover:bg-dark rounded-lg transition-colors">
          Suivant
        </button>
        <button type="submit" id="submit-btn" class="hidden px-8 py-3 text-sm font-semibold text-white bg-accent-warm hover:bg-amber-500 rounded-lg transition-colors shadow-lg shadow-amber-500/25">
          Recevoir mes 3 devis gratuits
        </button>
      </div>

      <input type="hidden" name="type" value="devis" />
    </form>
  </div>

  <div id="devis-success" class="hidden text-center py-16">
    <div class="w-20 h-20 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-10 h-10 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    </div>
    <h3 class="text-2xl font-heading font-bold text-text">Votre demande a été envoyée !</h3>
    <p class="mt-3 text-text-muted">Vous recevrez jusqu'à 3 devis gratuits sous 48h de la part d'artisans RGE certifiés de votre région.</p>
    <a href="/" class="mt-6 inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-primary hover:bg-dark rounded-lg transition-colors">
      Retour à l'accueil
    </a>
  </div>
</div>

<script>
  let currentStep = 1;
  const totalSteps = 4;

  const steps = [1, 2, 3, 4].map(n => document.getElementById(`step-${n}`)!);
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const progressBar = document.getElementById('progress-bar')!;
  const stepLabel = document.getElementById('step-label')!;
  const stepPercent = document.getElementById('step-percent')!;
  const form = document.getElementById('devis-form') as HTMLFormElement;
  const container = document.getElementById('devis-form-container')!;
  const success = document.getElementById('devis-success')!;

  function updateUI() {
    steps.forEach((s, i) => s.classList.toggle('hidden', i !== currentStep - 1));
    prevBtn.classList.toggle('hidden', currentStep === 1);
    nextBtn.classList.toggle('hidden', currentStep === totalSteps);
    submitBtn.classList.toggle('hidden', currentStep !== totalSteps);
    const pct = Math.round((currentStep / totalSteps) * 100);
    progressBar.style.width = `${pct}%`;
    stepLabel.textContent = `Étape ${currentStep} sur ${totalSteps}`;
    stepPercent.textContent = `${pct}%`;
  }

  prevBtn.addEventListener('click', () => { if (currentStep > 1) { currentStep--; updateUI(); } });
  nextBtn.addEventListener('click', () => { if (currentStep < totalSteps) { currentStep++; updateUI(); } });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data: Record<string, unknown> = {};
    formData.forEach((val, key) => {
      if (key === 'travaux') {
        if (!data.travaux) data.travaux = [];
        (data.travaux as string[]).push(val as string);
      } else {
        data[key] = val;
      }
    });
    try {
      await fetch('/.netlify/functions/send-contact-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      container.classList.add('hidden');
      success.classList.remove('hidden');
    } catch {
      alert('Erreur lors de l\'envoi. Veuillez réessayer.');
    }
  });
</script>
